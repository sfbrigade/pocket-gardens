{
  "type": "module",
  "name": "pocket-gardens-server",
  "version": "7.0.0",
  "main": "app.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "dev": "prisma migrate deploy; prisma db push --accept-data-loss; npm run prisma:generate; fastify start -w -l info -P app.js",
    "lint": "eslint --fix",
    "lint:check": "eslint",
    "pretest": "eslint",
    "prisma:generate": "prisma generate; tsc",
    "prisma:studio": "prisma studio",
    "start": "fastify start -l info app.js",
    "test": "node --test-concurrency 1 --test $(find test -name '*.test.js')",
    "tsc:watch": "tsc --watch --preserveWatchOutput"
  },
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/cloudfront-signer": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@fastify/autoload": "^6.3.1",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/url-data": "^6.0.3",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@scalar/fastify-api-reference": "^1.48.8",
    "accepts": "^1.3.8",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.5",
    "email-templates": "^13.0.1",
    "es-toolkit": "^1.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "fastify-zod-openapi": "^5.5.0",
    "http-status-codes": "^2.3.0",
    "inflection": "^3.0.2",
    "luxon": "^3.7.2",
    "mime-types": "^3.0.2",
    "nodemailer": "^8.0.4",
    "pm2": "^6.0.14",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@sfcivictech/prisma-fixtures": "^1.0.0",
    "@testcontainers/postgresql": "^11.12.0",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "fastify-cli": "^7.4.1",
    "neostandard": "^0.13.0",
    "nodemailer-mock": "^2.0.9",
    "prisma": "^7.5.0",
    "testcontainers": "^11.12.0",
    "typescript": "^5.7.2",
    "yaml": "^2.8.2"
  },
  "imports": {
    "#lib/*.js": "./lib/*.js",
    "#models/*.js": "./models/*.js",
    "#prisma/*.js": "./prisma/*.js",
    "#test/*.js": "./test/*.js"
  }
}